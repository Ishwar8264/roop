# Purpose: Pre-push quality gate
# Responsibility: Block pushes when React Doctor or production build fails
# Important Notes:
#   - Keep this hook simple and deterministic
#   - Mirrors the pre-commit checks so pushed code is re-verified

echo ""
echo "🩺 Running React Doctor before push..."
pnpm run doctor
DOCTOR_EXIT=$?

if [ $DOCTOR_EXIT -ne 0 ]; then
  echo ""
  echo "❌ Push blocked: React Doctor failed."
  echo "   Fix the reported issues, then try pushing again."
  echo ""
  exit 1
fi

echo ""
echo "🏗️  Running production build before push..."
pnpm run build
BUILD_EXIT=$?

if [ $BUILD_EXIT -ne 0 ]; then
  echo ""
  echo "❌ Push blocked: production build failed."
  echo "   Run 'pnpm run build' locally, fix the error, then push again."
  echo ""
  exit 1
fi

echo ""
echo "✅ Pre-push checks passed."
