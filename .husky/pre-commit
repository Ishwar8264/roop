# Purpose: Pre-commit quality gate
# Responsibility: Block commits when React Doctor or production build fails
# Important Notes:
#   - Keep this hook simple and deterministic
#   - The same checks also run before push

echo ""
echo "🩺 Running React Doctor before commit..."
pnpm run doctor
DOCTOR_EXIT=$?

if [ $DOCTOR_EXIT -ne 0 ]; then
  echo ""
  echo "❌ Commit blocked: React Doctor failed."
  echo "   Fix the reported issues, then try committing again."
  echo ""
  exit 1
fi

echo ""
echo "🏗️  Running production build before commit..."
pnpm run build
BUILD_EXIT=$?

if [ $BUILD_EXIT -ne 0 ]; then
  echo ""
  echo "❌ Commit blocked: production build failed."
  echo "   Run 'pnpm run build' locally, fix the error, then commit again."
  echo ""
  exit 1
fi

echo ""
echo "✅ Pre-commit checks passed."
