# ============================================
# Nikharta Roop (निखरता रूप) — Environment Config
# ============================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values
# 3. NEVER commit .env to git
# ============================================

# ─── PostgreSQL Database (REQUIRED) ───────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nikharta_roop?schema=public

# ─── JWT Secrets (REQUIRED) ──────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here-min-32-chars-long!!
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars-long!!

# ─── App Config ──────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=निखरता रूप
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Google OAuth (optional — for Google Login) ──────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Redis (optional — for OTP & rate limiting) ──────────
# If not set, OTP will be shown in console (dev mode)
REDIS_URL=redis://localhost:6379
