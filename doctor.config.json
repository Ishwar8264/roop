{
  "$schema": "https://react.doctor/schema/config.json",
  "rules": {
    "react-doctor/design-no-redundant-size-axes": "off",
    "react-doctor/design-no-em-dash-in-jsx-text": "off",
    "react-doctor/design-no-redundant-padding-axes": "off",
    "react-doctor/design-no-vague-button-label": "off",
    "react-doctor/no-dark-mode-glow": "off",
    "react-doctor/no-gradient-text": "off",
    "react-doctor/no-pure-black-background": "off",
    "react-doctor/no-side-tab-border": "off",
    "react-doctor/design-no-space-on-flex-children": "off",
    "react-doctor/design-no-three-period-ellipsis": "off",
    "react-doctor/jsx-no-constructed-context-values": "off",
    "react-doctor/no-danger": "off",
    "react-doctor/anchor-has-content": "off",
    "react-doctor/prefer-tag-over-role": "off",
    "react-doctor/no-redundant-roles": "off",
    "react-doctor/only-export-components": "off",
    "react-doctor/no-multi-comp": "off",
    "react-doctor/require-pnpm-hardening": "off"
  },
  "ignore": {
    "tags": [
      "test-noise"
    ]
  }
}
