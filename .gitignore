# ============================================
# Nikharta Roop (निखरता रूप) — .gitignore
# ============================================

# Dependencies
node_modules/
/.pnp
.pnp.*

# Next.js
/.next/
/out/

# Production
/build

# Environment files — NEVER commit .env
.env
.env.local
.env.*.local
!.env.example

# Debug & Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
dev.log
dev.out.log
server.log

# TypeScript
*.tsbuildinfo
next-env.d.ts

# OS files
.DS_Store
Thumbs.db
*.pem

# IDE
.vscode/
.idea/
*.swp
*.swo

# Vercel
.vercel

# Testing
/coverage

# AI Agent files (local only)
.claude/
.z-ai-config
agent-ctx/
worklog.md
.zscripts/

# Skills (platform-specific, not project code)
/skills/

# Download / screenshots
/download/

# Database files (local only)
db/
.pgsql/

# PM2 / Process management
ecosystem.config.cjs
logs/

# Lock files (keep only pnpm-lock.yaml)
package-lock.json
bun.lock

# Prisma backup
prisma/schema.prisma.pg.backup
prisma/schema-auth.prisma

# Misc dev artifacts
mini-services/
examples/
upload/
Caddyfile
setup-db.sh
start.sh
test-all-endpoints.sh
test-api.mjs
ENGINEERING_GUIDELINES.md
